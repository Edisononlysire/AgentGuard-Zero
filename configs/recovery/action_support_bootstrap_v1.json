{
  "protocol_version": "action-support-bootstrap-v1",
  "zero_definition": "zero_human_labeled_optimal_defense_actions",
  "execution_scope": {
    "allowed_now": [
      "stage0_fixed_policy_gate",
      "public_teacher_behavior_audit",
      "bootstrap_data_build_after_accepted_stage0"
    ],
    "locked_until_teacher_review": [
      "gate_a_dual_arm_bootstrap_sft",
      "gate_a_model_evaluation",
      "single_dagger_correction",
      "gate_b_10_step_rl",
      "full_static_skill_rl",
      "new_dca0",
      "dca_vda_coevolution",
      "ecrg_v5c_calibration"
    ]
  },
  "lineage": {
    "qwen3.5_base": "bootstrap_initialization_candidate",
    "vda_1": "bootstrap_initialization_candidate_contract_stable_action_inert",
    "vda_2": "excluded_contract_collapse",
    "vda_3": "excluded_contract_collapse",
    "dca_1": "diagnostic_only",
    "dca_2": "excluded_invalid_feedback_lineage",
    "dca_3": "excluded_invalid_feedback_lineage",
    "ecrg_v5c": "negative_runtime_diagnostic_only",
    "old_three_round_data": "failure_analysis_only_not_training"
  },
  "teacher": {
    "type": "finite_counterfactual_public_state_robust_teacher",
    "advantage_delta": 0.05,
    "hidden_worlds_minimum": 2,
    "common_horizon": 3,
    "beam_width": 20,
    "max_public_candidates": 96,
    "shortlist_quotas": {
      "observe": 1,
      "passive_verification": 3,
      "active_probe": 4,
      "trust": 3,
      "memory": 3,
      "mitigation": 6
    },
    "core_rank_correlation_min_exclusive": 0.5,
    "hidden_state_usage": "offline_utility_only",
    "model_input_hidden_state": false,
    "model_target_hidden_state": false
  },
  "bootstrap_sft": {
    "arms": ["qwen3.5_base", "vda_1"],
    "same_data_and_hyperparameters": true,
    "scenarios_per_arm": 400,
    "decision_records": [2000, 3000],
    "epochs": 1,
    "lora_rank": 16,
    "lora_alpha": 32,
    "lora_target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "learning_rate": 1e-5,
    "effective_batch_size": 64,
    "warmup_ratio": 0.03,
    "weight_decay": 0.01,
    "unique_prompt_target_ratio_min": 0.95
  },
  "gate_a": {
    "evaluation": {
      "original_gate": 80,
      "new_canonical": 120,
      "candidate_count": 1,
      "decoding": "greedy"
    },
    "minimums": {
      "action_validity": 0.99,
      "active_probe_rate": 0.10,
      "attack_mitigation": 0.15,
      "safe_success": 0.10,
      "probe_yield_exclusive": 0.0,
      "trust_memory_operation_rate": 0.05
    },
    "maximums": {
      "actionable_observe_rate": 0.70,
      "invalid_operation_rate": 0.02
    }
  },
  "dagger": {
    "passes": 1,
    "canonical_scenarios": 500,
    "correction_records": [1000, 3000]
  },
  "gate_b": {
    "scenarios": [160, 320],
    "rl_steps": 10,
    "rollouts": "adaptive_2_to_4",
    "temperature": 0.8,
    "top_p": 0.95,
    "bootstrap_replay_ratio": 0.20,
    "use_kl_loss": true,
    "kl_coef": 0.02,
    "action_validity_min": 0.98,
    "actionable_observe_max": 0.80,
    "requires_safe_utility_improvement": true,
    "requires_non_decreasing_mitigation": true,
    "requires_positive_probe_yield": true
  },
  "constrained_decoding": {
    "ppo_allowed_only_with_identical_rollout_and_logprob_token_mask": true
  },
  "v5c": {
    "allowed_during_training": false,
    "allowed_for_checkpoint_selection": false,
    "allowed_after_train_k1_gate": true
  }
}
